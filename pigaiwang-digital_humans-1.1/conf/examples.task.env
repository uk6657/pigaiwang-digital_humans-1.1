# ===================== 基本配置 ====================
# Worker ID
# 默认行为是自动生成 (主机名-进程ID)。如果取消注释并赋值，将覆盖自动生成的值。
# WORKER_ID=custom-worker-01

# ===================== 心跳相关 ====================
# 心跳间隔（秒）：Worker 每隔多久更新一次心跳
HEARTBEAT_INTERVAL=10

# 心跳超时阈值（秒）：超过此时间未更新心跳视为异常
HEARTBEAT_TIMEOUT=30

# ==================== 定时器相关 ====================
# 扫描间隔（秒）：定时器每隔多久扫描一次待处理任务
SCAN_INTERVAL=30

# PENDING 超时阈值（秒）：pending 状态超过此时间会被重新提交
PENDING_TIMEOUT=30

# ==================== Redis 锁相关 ====================
# 锁过期时间（秒）：建议与心跳超时保持一致或略大
LOCK_EXPIRE_SECONDS=45

# 锁的 Key 前缀
LOCK_KEY_PREFIX=task_lock:

# ==================== 任务控制 ====================
# 最大同时运行任务数
MAX_RUNNING_TASKS=100

# 默认最大重试次数
DEFAULT_MAX_RETRIES=3

# ==================== Worker 资源设置 ====================
# 进程池大小（用于 CPU 密集型计算）
PROCESS_POOL_SIZE=4

# 线程池大小（用于 IO 密集型操作）
THREAD_POOL_SIZE=10

# ==================== 取消检测相关 ====================
# 每处理多少个项目检查一次取消状态
CANCEL_CHECK_INTERVAL=100

# ==================== 日志相关 ====================
# 日志目录路径
LOG_DIR=./logs/tasks

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=DEBUG

# 日志轮转策略
LOG_ROTATION=1 week

# 日志保留时间
LOG_RETENTION=1 month