# ============================================================================
# 项目基础配置
# ============================================================================

# 运行环境：dev / test / prod
ENV=dev

# 服务端口号（建议 8000 或 8080，避免冲突）
PROJECT_PORT=1515

# 服务监听地址：0.0.0.0 表示所有接口都能访问
PROJECT_HOST=0.0.0.0
 
# 项目名称（用于日志、文档标题等）
PROJECT_NAME=ai-manhua

# API 路由前缀（建议保持 /api/v1，便于版本管理）
API_PREFIX=/api/v1

# ============================================================================
# 数据库配置（PostgreSQL）
# ============================================================================

# PostgreSQL 连接字符串（异步）
# 格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+asyncpg://postgres:Pg%24ch0l2%40r0Gu%402rd%216@118.253.178.241:1167/ai_comic_canvas
# postgresql密码为 Pg$ch0l2@r0Gu@2rd!6

# 是否在日志中打印 SQL 语句（开发时建议 true，生产 false）
DATABASE_ECHO=true


# ============================================================================
# 对象存储配置（图片/视频/音频存储）
# ============================================================================

# RustFS 配置（S3 兼容）
S3_URL=http://118.253.178.241:1168
S3_PUBLIC_URL=http://118.253.178.241:1168
S3_ACCESS_KEY='AKIAVRUSTFS7XQ9M2Y4L'
S3_SECRET_KEY='jK8#pLm$2nRv!qWx5tZcEaBdFgHhJkLmNnPpQrStUvWxYz1A3B5C'
S3_REGION=us-east-1
S3_MAX_POOL_CONNECTIONS=50
S3_SECURE=false                         # 因为是 http，不是 https
S3_OBJECT_PUBLIC_READ=false
S3_PUBLIC_READ_POLICY=false
S3_USE_PRESIGNED_DOWNLOAD_URL=false
S3_PRESIGNED_DOWNLOAD_EXPIRES=3600

# ============================================================================
# JWT 认证配置
# ============================================================================

# JWT 签名密钥（生产环境必须换成强随机字符串！）
SECRET_KEY=your_very_long_random_secret_key_change_me

# JWT 算法（HS256 够用）
ALGORITHM=HS256

# 访问令牌过期时间（分钟），建议 1440（1天）或 10080（7天）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# 默认管理员账户配置
# ============================================================================

# 默认管理员信息
DEFAULT_SYSTEM_ADMINS=[{"username": "admin1", "password": "Admin123456", "phone": "+8613800138000"}, {"username": "admin2", "password": "Admin123456", "phone": "+8613800139000"}]

# 默认管理员角色
DEFAULT_ADMIN_ROLE=admin

# ============================================================================
# Redis 配置（异步任务队列、缓存、限流等）
# ============================================================================


# Redis 连接地址
# Redis密码为R3d_s_S3cur3_K3y7mQ9
REDIS_URL=redis://:R3d_s_S3cur3_K3y7mQ9@118.253.178.241:1166
